# FROM python:3.11-slim

# # Create user first, then set up the workspace with correct ownership
# RUN useradd -m sandboxuser && mkdir -p /app && chown sandboxuser:sandboxuser /app

# # Install uvicorn as root so it's available system-wide
# RUN pip install --no-cache-dir uvicorn

# WORKDIR /app

# # Switch to sandboxuser — pip installs will go to ~/.local/bin
# USER sandboxuser

# # Make sure ~/.local/bin is on PATH so uvicorn and installed CLIs are found
# ENV PATH="/home/sandboxuser/.local/bin:$PATH"

# EXPOSE 8000

# # No CMD needed — overridden by sleep infinity at runtime


FROM python:3.11-slim

# Install system utilities:
# - util-linux  → provides setsid (detach process from exec session)
# - procps      → provides ps, kill (useful for debugging inside container)
RUN apt-get update && apt-get install -y --no-install-recommends \
    util-linux \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Pre-install uvicorn so it's always available regardless of user's requirements.txt
RUN pip install --no-cache-dir uvicorn

WORKDIR /app

EXPOSE 8000

# No CMD — create_container() overrides it with "sleep infinity" anyway